#include 'cxx/lexer.lv'

if __args__.size < 3
  out 'Usage: lavi --cxx <file>'
  return 1
end

var cxx_file_path = __args__[2]

unless File.exists?(cxx_file_path)
  out "Input file '${cxx_file_path}' not found."
  return 1
end

var cxx_file = File.read(cxx_file_path)

fn debug(message)
  out message
end

debug "Tokenizing CXX file ${cxx_file_path}..."

var lexer = CXX.Lexer.new(cxx_file)

out lexer.tokens