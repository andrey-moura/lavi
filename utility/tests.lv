#include 'std/tests'

out "current_dir: ${Dir.current}"

var spec_files = Dir.current.glob('tests/**/*_spec.lv')

var tests_path = Dir.current.path / 'tests'

out "tests_path: ${tests_path}"
out "tests_path.exists?: ${tests_path.exists?}"
out "high_level.exists?: ${Path.new(tests_path / 'high-level').exists?}"

out "spec_files: ${spec_files}"

spec_files.each do (file)
  if __args__.size > 2
    __args__.each do(arg)
      if file.to_string.ends_with?(arg)
        require file
        break
      end
    end
  else
    require file
  end
end

print_summary

failed_tests