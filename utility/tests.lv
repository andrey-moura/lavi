#include 'std/tests'

out "current_dir: ${Dir.current}"

var spec_files = Dir.current.glob('tests/**/*_spec.lv')

var tests_path = Path.new(Dir.current.path / 'tests')

out tests_path.exists?

spec_files.each do (file)
  if __args__.size > 2
    __args__.each do(arg)
      if file.to_string.ends_with?(arg)
        require file
        break
      end
    end
  else
    require file
  end
end

print_summary

failed_tests