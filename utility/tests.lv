#include 'std/tests'

var tests_dir = Dir.current.glob('tests/**/*_spec.lv')

tests_dir.each do (file)
  if __args__.size > 2
    __args__.each do(arg)
      if file.to_string.ends_with?(arg)
        require file
        break
      end
    end
  else
    require file
  end
end

print_summary

failed_tests