namespace CXX
  type Lexer
    var file = null
    var tokens = null

    fn init(f)
      file = f
      tokens = tokenize
    end

    fn peek_char
      file.front
    end

    fn discard_whitespaces
      var c = peek_char
      out "Peeking char: '${c}'"
    end

    fn read_next_token
      discard_whitespaces
    end

    fn tokenize
      // Placeholder for actual tokenization logic
      read_next_token
      return ["token1", "token2", "token3"]
    end
  end
end