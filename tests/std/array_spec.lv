#include 'std/tests'

describe 'array' do
  describe '#empty?' do
    context 'when the array is empty' do
      it 'returns true' do
        var arr = []

        expect(arr.empty?).to eq(true)
      end
    end
    context 'when the array is not empty' do
      it 'returns false' do
        var arr = [1, 2, 3]

        expect(arr.empty?).to eq(false)
      end
    end
  end
  describe '#include?' do
    context 'when the array includes the element' do
      it 'returns true' do
        var arr = [1, 2, 3]

        expect(arr.include?(2)).to eq(true)
      end
    end
    context 'when the array does not include the element' do
      it 'returns false' do
        var arr = [1, 2, 3]

        expect(arr.include?(4)).to eq(false)
      end
    end
  end
  describe 'map!' do
    it 'modifies the array in place' do
      var arr = [1, 2, 3]

      arr.map! do(x)
        x * 2
      end

      expect(arr).to eq([2, 4, 6])
    end
  end
  describe '#sort' do
    it 'sorts the array in ascending order' do
      var arr = [3, 1, 2]

      var sorted_arr = arr.sort

      expect(sorted_arr).to eq([1, 2, 3])
    end
  end
end