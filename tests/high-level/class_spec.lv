#include 'std/tests'

describe 'class' do
  context 'when creating instances' do
    it 'initializes instance variables with default values' do
      class Foo
        var x = 42
      end

      var f = Foo.new
      expect(f.x).to eq(42)
    end

    it 'applies constructor assignments during initialization' do
      class Foo
        var x = null

        fn init
          x = 123
        end
      end

      var f = Foo.new
      expect(f.x).to eq(123)
    end

    it 'keeps default values when constructor does not override them' do
      class Foo
        var x = 7

        fn init
          var noop = null
        end
      end

      var f = Foo.new
      expect(f.x).to eq(7)
    end
  end
  context 'when defining instance methods' do
    it 'modifies internal state through method calls' do
      class Counter
        var count = 0

        fn inc
          count += 1
        end
      end

      var c = Counter.new
      c.inc
      c.inc

      expect(c.count).to eq(2)
    end

    it 'returns values based on current instance state' do
      class Counter
        var count = 0

        fn inc
          count += 1
        end

        fn current
          return count
        end
      end

      var c = Counter.new
      c.inc
      c.inc

      expect(c.current).to eq(2)
    end
  end
  context 'when using method parameters' do
    it 'uses arguments to update state' do
      class Multiplier
        var result = 1

        fn mul(n)
          result *= n
        end
      end

      var m = Multiplier.new
      m.mul 5
      m.mul 2

      expect(m.result).to eq(10)
    end

    it 'supports multiple sequential updates with different values' do
      class Accumulator
        var total = 0

        fn add(n)
          total += n
        end
      end

      var a = Accumulator.new
      a.add 3
      a.add 10
      a.add -4

      expect(a.total).to eq(9)
    end
  end
  context 'when using static methods' do
    it 'calls static methods without creating an instance' do
      class Math
        static fn double(n)
          return n * 2
        end
      end

      expect(Math.double(4)).to eq(8)
    end

    it 'allows static methods to be called multiple times with different inputs' do
      class Math
        static fn double(n)
          return n * 2
        end
      end

      expect(Math.double(1)).to eq(2)
      expect(Math.double(10)).to eq(20)
      expect(Math.double(-3)).to eq(-6)
    end
  end
  context 'when handling multiple instances' do
    it 'isolates state between different objects' do
      class Box
        var value = null

        fn set(v)
          value = v
        end
      end

      var a = Box.new
      var b = Box.new

      a.set 10
      b.set 20

      expect(a.value).to eq(10)
      expect(b.value).to eq(20)
    end

    it 'does not leak updates from one instance to another' do
      class Box
        var value = 0

        fn set(v)
          value = v
        end
      end

      var first = Box.new
      var second = Box.new

      first.set 99

      expect(first.value).to eq(99)
      expect(second.value).to eq(0)
    end
  end
  context 'when redefining a type' do
    it 'accumulates members across type reopenings' do
      class User
        var name = null
      end

      class User
        fn set_name(value)
          name = value
        end
      end

      var u = User.new
      u.set_name 'andrey'

      expect(u.name).to eq('andrey')
    end
  end
  context 'when being assigned to a variable' do
    it 'allows retreiving the name of the type' do
      class Person
        var name = null
      end

      var p = Person
      expect(p.name).to eq('Person')
    end
    it 'allows creating instances through the variable' do
      class Person
        var name = null

        fn init(n)
          name = n
        end
      end

      var P = Person
      var p1 = P.new('Alice')
      var p2 = P.new('Bob')

      expect(p1.name).to eq('Alice')
      expect(p2.name).to eq('Bob')
    end
  end
  context 'with base' do
    it 'inherits instance variables' do
      class Animal
        var species = null

        fn init
          species = 'generic animal'
        end
      end

      class Dog extends Animal
      end

      var d = Dog.new
      expect(d.species).to eq('generic animal')
    end
    it 'inherits instance methods' do
      class Speaker
        fn speak(what)
          what
        end
      end

      class Dog extends Speaker
        fn bark
          speak :woof
        end
      end

      var d = Dog.new
      expect(d.bark).to eq('woof')
    end
    context 'undefined' do
      context 'not instiated' do
        it 'does not throw error' do
          class Person extends Animal
          end
        end
      end
    end
  end
  context 'when declaring variable inside instance function' do
    it 'should not be accessible outside the function' do
      class FooWithBarFunction
        fn bar
          var x = 42
          x
        end
      end

      var f = FooWithBarFunction.new
      expect(f.bar).to eq(42)

      var exeception = null

      try
        f.x
      catch(e)
        exeception = e
      end

      if exeception
        expect(exeception.class).to eq(NoFunctionError)
      else
        throw ExpectationNotMetError.new('no exception thrown')
      end
    end
  end
end
