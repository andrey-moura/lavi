#include 'std/tests'

describe 'std functions' do
  describe '__file__' do
    it 'should evaluate to the current file path' do
      if System.windows?
        expect(__file__).to ends_with('\tests\high-level\std_functions_spec.lv')
      else
        expect(__file__).to ends_with('/tests/high-level/std_functions_spec.lv')
      end
    end
  end
  describe '__dir__' do
    it 'should evaluate to the current file directory' do
      if System.windows?
        expect(__dir__).to ends_with('\tests\high-level')
      else
        expect(__dir__).to ends_with('/tests/high-level')
      end
    end
  end
  describe 'require' do
    fn fixture(name)
      var path = Dir.current.path
      path /= 'tests'
      path /= 'fixtures'
      path /= "${name}.lv"
    end
    context 'when a file is required' do
      it 'should evaluate the expression' do
        expect(require fixture('1')).to eq 1
      end
      it 'should load definitions' do
        require fixture('fn')

        expect(test).to eq '123'
      end
    end
  end
end