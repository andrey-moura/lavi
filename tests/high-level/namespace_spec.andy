#include 'std/tests'

describe 'namespace' do
  context 'when defining a namespace' do
    it 'groups definitions under the namespace path' do
      namespace Foo
        type Bar
          var x = 42
        end
      end

      var b = Foo.Bar.new
      expect(b.x).to eq(42)
    end

    it 'supports multiple type definitions in the same namespace' do
      namespace Foo
        type A
          var value = 1
        end

        type B
          var value = 2
        end
      end

      var a = Foo.A.new
      var b = Foo.B.new

      expect(a.value).to eq(1)
      expect(b.value).to eq(2)
    end

    it 'allows types in the same namespace to coexist with static utilities' do
      namespace Toolbox
        type Counter
          var value = 0
        end

        type Math
          static fn inc(n)
            return n + 1
          end
        end
      end

      var c = Toolbox.Counter.new
      expect(c.value).to eq(0)
      expect(Toolbox.Math.inc(9)).to eq(10)
    end
  end

  context 'when nesting namespaces' do
    it 'resolves types inside nested namespaces' do
      namespace A
        namespace B
          type T
            var msg = 'ok'
          end
        end
      end

      var t = A.B.T.new
      expect(t.msg).to eq('ok')
    end

    it 'resolves static methods through nested namespace paths' do
      namespace Core
        namespace Convert
          type Hex
            static fn twice(n)
              return n * 2
            end
          end
        end
      end

      expect(Core.Convert.Hex.twice(6)).to eq(12)
    end
  end

  context 'when accessing a type outside its namespace' do
    // Andy does not have exceptions, so this behavior is documented as pending.
    pending 'does not resolve names without full qualification' do
      namespace Alpha
        type Hidden
          var data = 123
        end
      end

      var h = Hidden.new
    end
  end

  context 'when using namespaces with static methods' do
    it 'calls static methods using the full namespace path' do
      namespace Utils
        type Math
          static fn triple(n)
            return n * 3
          end
        end
      end

      expect(Utils.Math.triple(3)).to eq(9)
    end
  end

  context 'when reopening a type inside a namespace' do
    it 'accumulates members across type reopenings' do
      namespace MyLib
        type Item
          var v = null
        end

        type Item
          fn set(v2)
            v = v2
          end
        end
      end

      var i = MyLib.Item.new
      i.set 'X'

      expect(i.v).to eq('X')
    end
  end

  context 'when reusing namespace names' do
    it 'accumulates classes when the same namespace is defined twice' do
      namespace MyLib
        type A
          var v = 'A'
        end
      end

      namespace MyLib
        type B
          var v = 'B'
        end
      end

      var a = MyLib.A.new
      var b = MyLib.B.new

      expect(a.v).to eq('A')
      expect(b.v).to eq('B')
    end
  end
end
