#include 'std/tests.lv'

describe 'Hash' do
  context 'declaration' do
    context 'with literal syntax' do
      context 'using symbol keys' do
        var hash = { key: "value" }
        it 'should allow accessing values with symbol keys' do
          expect(hash[:key]).to eq("value")
        end
        it 'should allow accessing values with string keys' do
          expect(hash["key"]).to eq("value")
        end
      end
      context 'using string keys' do
        var hash = { "key": "value" }
        it 'should allow accessing values with symbol keys' do
          expect(hash[:key]).to eq("value")
        end
        it 'should allow accessing values with string keys' do
          expect(hash["key"]).to eq("value")
        end
      end
    end
  end
end