type ExpectationNotMet extends RuntimeError
    var message = null
    fn init(msg)
        message = msg
    end
end

type EQ
    var expected = null
    fn init(value)
        expected = value
    end

    fn match(actual)
        if actual == expected
            return true
        else
            throw ExpectationNotMet.new("Expected ${expected.inspect}, but got ${actual.inspect}")
        end
    end
end

type Include
    var expected = null
    fn init(value)
        expected = value
    end

    fn match(actual)
        if actual.include?(expected)
            return true
        else
            throw ExpectationNotMet.new("Expected ${actual} to include ${expected}")
        end
    end
end

type EndsWith
    var expected = null
    fn init(value)
        expected = value
    end

    fn match(actual)
        if actual.ends_with?(expected)
            return true
        else
            throw ExpectationNotMet.new("Expected ${actual} to end with ${expected}")
        end
    end
end

type Expect
    var actual = null
    fn init(value)
        actual = value
    end

    fn to(matcher)
        matcher.match(actual)
    end
end

var describe_stack = []
var current_describe_level = 0
var errors = []
var total_tests = 0
var failed_tests = 0
var pending_tests = 0
var passed_tests = 0

fn indent(str)
    var ident_level = "  " * current_describe_level
    ident_level + str
end

fn success(str)
    "\x1b[32m${str}\x1b[0m"
end

fn error(str)
    "\x1b[31m${str}\x1b[0m"
end

fn warning(str)
    "\x1b[33m${str}\x1b[0m"
end

fn describe(what)
    out indent what
    current_describe_level += 1
    describe_stack.push(what)
    yield
    current_describe_level -= 1
    describe_stack.pop
end

fn context(what)
    out indent "${what}"
    current_describe_level += 1
    describe_stack.push(what)
    yield
    current_describe_level -= 1
    describe_stack.pop
end

fn it(what)
    var error_msg = null
    try
        yield
    catch(ExpectationNotMet e)
        error_msg = e.message
        errors.push("${describe_stack.join(' ')} ${what}\n${error_msg}")
    catch(e)
        error_msg = "Unexpected error: ${e.inspect}"
        errors.push("${describe_stack.join(' ')} ${what}\n${error_msg}")
    end
    total_tests += 1
    if error_msg.present?
        out error indent "${what}"
        failed_tests += 1
    else
        out success indent "${what}"
        passed_tests += 1
    end
end

fn eq(what)
    EQ.new(what)
end

fn include(what)
    Include.new(what)
end

fn expect(value)
    Expect.new(value)
end

fn ends_with(what)
    EndsWith.new(what)
end

fn pending(what)
    out indent warning "${what} (pending)"
    total_tests += 1
    pending_tests += 1
end

fn print_summary()
    out "\nTest Summary:"

    var summary = "\n${total_tests} total, ${passed_tests} passed, ${pending_tests} pending, ${failed_tests} failed"

    if failed_tests.positive?
        out ''
        out error errors.join("\n\n")
        out error summary
    else if pending_tests.positive?
        out warning summary
    else
        out success summary
    end
end